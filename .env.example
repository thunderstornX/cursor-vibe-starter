# --- service ---
APP_NAME=security-microservice
ENV=dev
LOG_LEVEL=INFO
PORT=8080

# --- auth ---
# Generate a strong key for production: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
JWT_SECRET=replace-me-in-production-or-the-service-will-refuse-to-start
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=60

# --- redis (rate limiter + scan queue) ---
REDIS_URL=redis://redis:6379/0

# --- rate limit ---
RATE_LIMIT_PER_MINUTE=30
